<Window x:Class="PedestrianCrossing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PedestrianCrossing"
        xmlns:vm="clr-namespace:PedestrianCrossing.ViewModels"
        
        Title="Пешеходный переход" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Холст для анимации -->
        <Canvas x:Name="SceneCanvas" Grid.Row="0" Background="LightGray">
            <!-- Дорога -->
            <Rectangle Width="800" Height="100" Fill="Gray" Canvas.Left="0" Canvas.Top="120"/>
            <!-- Разметка перехода -->
            <Line X1="100" Y1="120" X2="100" Y2="220" Stroke="White" StrokeThickness="3"/>
            <Line X1="700" Y1="120" X2="700" Y2="220" Stroke="White" StrokeThickness="3"/>

            <!-- Светофор -->
            <Ellipse Width="30" Height="30" Canvas.Left="720" Canvas.Top="50"
                     Fill="{Binding TrafficLight.IsGreen, Converter={StaticResource BoolToColorConverter}}"/>
            <TextBlock Canvas.Left="760" Canvas.Top="55" Text="Светофор"/>

            <ItemsControl ItemsSource="{Binding Vehicles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                   Fill="Blue" Stroke="Black" RadiusX="5" RadiusY="5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding Pedestrians}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="{Binding Size}" Height="{Binding Size}"
                                 Fill="Green" Stroke="Black"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding EmergencyVehicles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                   Fill="Red" Stroke="Black" RadiusX="5" RadiusY="5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <ComboBox ItemsSource="{Binding VehicleTypes}" SelectedItem="{Binding SelectedVehicleType}"
                      Width="100" Margin="5"/>
            <Button Content="Добавить авто" Command="{Binding AddCarCommand}" Margin="5"/>
            <Button Content="Добавить пешехода" Command="{Binding AddPedestrianCommand}" Margin="5"/>
            <Button Content="Старт" Command="{Binding StartCommand}" Margin="5"/>
            <Button Content="Стоп" Command="{Binding StopCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>